generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, pgcrypto, uuid_ossp]
}

enum UserRole {
  client
  provider
  admin
  super_admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum BookingStatus {
  pending
  matching
  matched
  confirmed
  scheduled
  in_progress
  completed
  cancelled
  disputed
  refunded
}

enum PaymentStatus {
  pending
  authorized
  captured
  split_completed
  pro_paid
  refunded
  failed
}

enum DisputeType {
  delay
  quality
  no_show
  damage
  overcharge
  other
}

enum DisputeStatus {
  opened
  classifying
  auto_resolving
  chatbot
  proposed
  escalated
  resolved
  closed
}

enum VerificationStatus {
  pending
  documents_received
  verifying
  verified
  rejected
  suspended
  expired
}

enum DocumentType {
  siret
  diploma
  insurance_rc_pro
  identity
  other
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique
  phone         String?    @unique
  passwordHash  String     @map("password_hash")
  role          UserRole   @default(client)
  firstName     String     @map("first_name")
  lastName      String     @map("last_name")
  avatarUrl     String?    @map("avatar_url")
  status        UserStatus @default(active)
  emailVerified Boolean    @default(false) @map("email_verified")
  phoneVerified Boolean    @default(false) @map("phone_verified")
  lastLogin     DateTime?  @map("last_login")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  providerProfile  ProviderProfile?
  addresses        Address[]
  clientBookings   Booking[]        @relation("ClientBookings")
  providerBookings Booking[]        @relation("ProviderBookings")
  refreshTokens    RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model ProviderProfile {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String             @unique @map("user_id") @db.Uuid
  siret              String?            @unique
  bio                String?
  skills             String[]
  commissionRate     Decimal            @default(0.25) @map("commission_rate") @db.Decimal(4, 3)
  ratingAvg          Decimal            @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount        Int                @default(0) @map("rating_count")
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verificationScore  Decimal?           @map("verification_score") @db.Decimal(3, 2)
  maxRadiusKm        Int                @default(10) @map("max_radius_km")
  isAvailable        Boolean            @default(false) @map("is_available")
  stripeConnectId    String?            @map("stripe_connect_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id])
  documents      Document[]
  availabilities Availability[]

  @@map("provider_profiles")
}

model ServiceCategory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String    @unique
  icon        String?
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  services    Service[]

  @@map("service_categories")
}

model Service {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId      String          @map("category_id") @db.Uuid
  name            String
  description     String?
  basePrice       Decimal         @map("base_price") @db.Decimal(10, 2)
  durationMinutes Int             @map("duration_minutes")
  requirements    String[]
  isActive        Boolean         @default(true) @map("is_active")
  sortOrder       Int             @default(0) @map("sort_order")
  category        ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings        Booking[]

  @@map("services")
}

model Address {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  label      String?
  street     String
  complement String?
  city       String
  postalCode String   @map("postal_code")
  country    String   @default("FR")
  lat        Decimal? @db.Decimal(10, 8)
  lng        Decimal? @db.Decimal(11, 8)
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id])
  bookings   Booking[]

  @@map("addresses")
}

model Booking {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId           String        @map("client_id") @db.Uuid
  providerId         String?       @map("provider_id") @db.Uuid
  serviceId          String        @map("service_id") @db.Uuid
  addressId          String        @map("address_id") @db.Uuid
  status             BookingStatus @default(pending)
  scheduledAt        DateTime?     @map("scheduled_at")
  startedAt          DateTime?     @map("started_at")
  completedAt        DateTime?     @map("completed_at")
  totalPrice         Decimal       @map("total_price") @db.Decimal(10, 2)
  serviceFee         Decimal       @map("service_fee") @db.Decimal(10, 2)
  commissionAmount   Decimal       @map("commission_amount") @db.Decimal(10, 2)
  providerPayout     Decimal       @map("provider_payout") @db.Decimal(10, 2)
  notes              String?
  cancellationFee    Decimal?      @map("cancellation_fee") @db.Decimal(10, 2)
  cancelledBy        String?       @map("cancelled_by") @db.Uuid
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  client    User     @relation("ClientBookings", fields: [clientId], references: [id])
  provider  User?    @relation("ProviderBookings", fields: [providerId], references: [id])
  service   Service  @relation(fields: [serviceId], references: [id])
  address   Address  @relation(fields: [addressId], references: [id])
  payment   Payment?
  review    Review?
  disputes  Dispute[]
  agentLogs AgentLog[]

  @@map("bookings")
}

model Payment {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId             String        @unique @map("booking_id") @db.Uuid
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("EUR")
  commission            Decimal       @db.Decimal(10, 2)
  providerPayout        Decimal       @map("provider_payout") @db.Decimal(10, 2)
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  stripeTransferId      String?       @map("stripe_transfer_id")
  status                PaymentStatus @default(pending)
  authorizedAt          DateTime?     @map("authorized_at")
  capturedAt            DateTime?     @map("captured_at")
  payoutAt              DateTime?     @map("payout_at")
  refundAmount          Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  refundedAt            DateTime?     @map("refunded_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  booking               Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Review {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId      String   @unique @map("booking_id") @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  providerId     String   @map("provider_id") @db.Uuid
  rating         Int
  comment        String?
  sentimentScore Decimal? @map("sentiment_score") @db.Decimal(3, 2)
  sentimentLabel String?  @map("sentiment_label")
  themes         String[]
  isVerified     Boolean  @default(false) @map("is_verified")
  isFlagged      Boolean  @default(false) @map("is_flagged")
  createdAt      DateTime @default(now()) @map("created_at")
  booking        Booking  @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

model Dispute {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId           String        @map("booking_id") @db.Uuid
  openedBy            String        @map("opened_by") @db.Uuid
  type                DisputeType
  status              DisputeStatus @default(opened)
  description         String
  resolutionType      String?       @map("resolution_type")
  resolutionAmount    Decimal?      @map("resolution_amount") @db.Decimal(10, 2)
  resolutionNote      String?       @map("resolution_note")
  autoResolved        Boolean       @default(false) @map("auto_resolved")
  escalatedAt         DateTime?     @map("escalated_at")
  resolvedAt          DateTime?     @map("resolved_at")
  agentRecommendation String?       @map("agent_recommendation")
  agentConfidence     Decimal?      @map("agent_confidence") @db.Decimal(3, 2)
  createdAt           DateTime      @default(now()) @map("created_at")
  booking             Booking       @relation(fields: [bookingId], references: [id])

  @@map("disputes")
}

model AgentLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentName       String   @map("agent_name")
  action          String
  eventType       String   @map("event_type")
  input           Json?
  output          Json?
  decisionReason  String?  @map("decision_reason")
  confidenceScore Decimal? @map("confidence_score") @db.Decimal(3, 2)
  durationMs      Int?     @map("duration_ms")
  bookingId       String?  @map("booking_id") @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  error           String?
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  booking         Booking? @relation(fields: [bookingId], references: [id])

  @@map("agent_logs")
}

model Document {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId      String             @map("provider_id") @db.Uuid
  type            DocumentType
  fileUrl         String             @map("file_url")
  fileName        String             @map("file_name")
  status          VerificationStatus @default(pending)
  verifiedAt      DateTime?          @map("verified_at")
  expiresAt       DateTime?          @map("expires_at")
  ocrData         Json?              @map("ocr_data")
  rejectionReason String?            @map("rejection_reason")
  createdAt       DateTime           @default(now()) @map("created_at")
  provider        ProviderProfile    @relation(fields: [providerId], references: [id])

  @@map("documents")
}

model Availability {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId   String          @map("provider_id") @db.Uuid
  dayOfWeek    Int?            @map("day_of_week")
  startTime    String?         @map("start_time")
  endTime      String?         @map("end_time")
  isRecurring  Boolean         @default(true) @map("is_recurring")
  specificDate DateTime?       @map("specific_date")
  isBlocked    Boolean         @default(false) @map("is_blocked")
  provider     ProviderProfile @relation(fields: [providerId], references: [id])

  @@map("availabilities")
}
